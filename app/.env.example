# geo-base Admin UI 環境変数設定
# このファイルを .env.local にコピーして値を設定してください

# ===========================================
# API設定
# ===========================================

# タイルサーバーAPIのURL
# ローカル開発時 (省略時は next.config.ts の rewrites がデフォルト
# `http://localhost:8000` にプロキシする)
NEXT_PUBLIC_API_URL=http://localhost:8000

# 本番 (Vercel) では Cookie ベース認証のため Admin UI 自身の origin から
# /api/* を叩く同一オリジン構成。`NEXT_PUBLIC_API_URL` は **空** にし、
# server-side env として `API_BACKEND_URL=https://geo-base-api.fly.dev`
# を設定する (next.config.ts の rewrites が proxy 先として参照)。
# - Vercel project Environment Variables で `API_BACKEND_URL` を Production
#   に設定。Production scope で未設定だと build が fail-fast で停止する。
# - 末尾スラッシュは付けない (`https://example.com/` ではなく
#   `https://example.com`)。

# ===========================================
# MCPサーバー設定
# ===========================================

# MCPサーバーのURL
# ローカル開発時
NEXT_PUBLIC_MCP_URL=http://localhost:8001

# 本番環境を使う場合
# NEXT_PUBLIC_MCP_URL=https://geo-base-mcp.fly.dev

# ===========================================
# オプション設定
# ===========================================

# 開発モード（デバッグログの出力など）
# NODE_ENV=development
