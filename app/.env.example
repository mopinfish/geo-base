# geo-base Admin UI — environment variables
# Copy this file to `.env.local` and fill in values for your environment.

# ===========================================
# API settings
# ===========================================

# Tile server (FastAPI) URL.
# For local development this is usually left as below; when omitted,
# `next.config.ts`'s rewrites proxy `/api/*` to `http://localhost:8000` by default.
NEXT_PUBLIC_API_URL=http://localhost:8000

# In production (Vercel) we use cookie-based auth and hit `/api/*` from the
# Admin UI's own origin (same-origin proxy). In that setup:
#   - leave `NEXT_PUBLIC_API_URL` **empty**
#   - set the server-side env `API_BACKEND_URL=https://geo-base-api.fly.dev`
#     (`next.config.ts` rewrites uses it as the proxy target)
# Configure `API_BACKEND_URL` in the Vercel project's Environment Variables
# (Production scope). The build fails fast if it is missing in production.
# Do not include a trailing slash (use `https://example.com`, not `https://example.com/`).

# ===========================================
# MCP server settings
# ===========================================

# MCP server URL.
# Local development:
NEXT_PUBLIC_MCP_URL=http://localhost:8001

# Production (uncomment to use the deployed MCP server):
# NEXT_PUBLIC_MCP_URL=https://geo-base-mcp.fly.dev

# ===========================================
# Optional
# ===========================================

# Development mode (verbose debug logging, etc.)
# NODE_ENV=development
