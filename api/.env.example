# geo-base API Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Environment
# =============================================================================
ENVIRONMENT=development
DEBUG=true

# =============================================================================
# Database
# =============================================================================
# Local development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/geo_base

# Production (Fly Postgres, geo-base-pg app on Fly internal network)
# 詳細は docs/POSTGRES_SETUP.md を参照（ホスト名は `geo-base-pg.internal` で統一）
# DATABASE_URL=postgresql://postgres:[PASSWORD]@geo-base-pg.internal:5432/geo_base

# pytest 用テスト DB（issue #47）。dev DB の TRUNCATE 事故を防ぐため、
# DATABASE_URL とは別の DB を必ず指定すること。`docker compose up -d` 初回起動で
# geo_base_test が自動作成される（docker/postgis-init/99_create_test_db.sh）。
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/geo_base_test

# =============================================================================
# Authentication
# =============================================================================
# 詳細: docs/AUTH_SETUP.md
# 履歴（Supabase Auth → local 移行記録）: docs/AUTH_MIGRATION.md

# プロバイダ選択: local のみサポート（Supabase Auth は #72 で廃止）
AUTH_PROVIDER=local

# ---- 必須設定 ----
# JWT 署名鍵（openssl rand -base64 64 で生成。最低 32 byte 推奨）
JWT_SECRET=

# JWT audience claim
JWT_AUDIENCE=authenticated

# 招待・パスワードリセットリンクのベース URL（Admin UI の origin）
INVITATION_BASE_URL=http://localhost:3000

# サインアップを許可するか（false: 招待経由のみ）
LOCAL_AUTH_ALLOW_SIGNUP=false

# ---- メール送信設定 ----
# console: ターミナル出力（開発用） | smtp: 実送信 | null: 送信しない
EMAIL_BACKEND=console

# SMTP モード時のみ
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=
# SMTP_FROM=no-reply@geo-base.example

# ---- Cookie 設定 ----
# Same-site dev では lax、cross-site 本番は none + COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_SECURE=false
# 本番で複数サブドメイン共有時のみ設定（例: .example.com）
# COOKIE_DOMAIN=

# =============================================================================
# Storage (COG/PMTiles upload backend, S3 互換)
# =============================================================================
# 既定で Fly Tigris (https://fly.io/docs/tigris/) を想定。
# AWS S3 / Cloudflare R2 等を使う場合は S3_ENDPOINT_URL / S3_REGION を上書き。
# 認証情報は標準の AWS env で渡す（boto3 のデフォルト credential chain に乗る）。

# S3 endpoint URL（Tigris の場合の既定値）
# S3_ENDPOINT_URL=https://fly.storage.tigris.dev
# S3_REGION=auto
# S3_BUCKET=geo-base-tiles

# Public 配信用 base URL（任意）。未設定なら $S3_ENDPOINT_URL/$S3_BUCKET を使う。
# CDN を挟む場合のみ設定。
# S3_PUBLIC_BASE_URL=https://cdn.example.com/geo-base-tiles

# AWS credentials（fly secrets set で投入）
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# 旧 SUPABASE_* / BLOB_READ_WRITE_TOKEN は Issue #72 (PR #88) で廃止済み。

# =============================================================================
# CORS
# =============================================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=*

# =============================================================================
# Raster Tile Settings
# =============================================================================
# Default scale range for raster tiles
RASTER_DEFAULT_SCALE_MIN=0
RASTER_DEFAULT_SCALE_MAX=3000

# Default output format
RASTER_DEFAULT_FORMAT=png

# Maximum preview image size
RASTER_MAX_PREVIEW_SIZE=1024

# Tile size in pixels
RASTER_TILE_SIZE=256
