# geo-base API Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Environment
# =============================================================================
ENVIRONMENT=development
DEBUG=true

# =============================================================================
# Database
# =============================================================================
# Local development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/geo_base

# Production (Supabase) - Use Pooler connection (port 6543)
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# =============================================================================
# Authentication (Phase 3 / Step 3.3-A: プラガブル認証)
# =============================================================================
# 詳細: docs/AUTH_SETUP.md, docs/AUTH_MIGRATION.md

# プロバイダ選択: local (自前 JWT 発行) | supabase (Supabase Auth に委譲)
AUTH_PROVIDER=local

# ---- local モード必須 ----
# JWT 署名鍵（openssl rand -base64 64 で生成。最低 32 byte 推奨）
JWT_SECRET=

# JWT audience claim
JWT_AUDIENCE=authenticated

# 招待・パスワードリセットリンクのベース URL（Admin UI の origin）
INVITATION_BASE_URL=http://localhost:3000

# サインアップを許可するか（false: 招待経由のみ）
LOCAL_AUTH_ALLOW_SIGNUP=false

# ---- メール送信設定 ----
# console: ターミナル出力（開発用） | smtp: 実送信 | null: 送信しない
EMAIL_BACKEND=console

# SMTP モード時のみ
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=
# SMTP_FROM=no-reply@geo-base.example

# ---- Cookie 設定 ----
# Same-site dev では lax、cross-site 本番は none + COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_SECURE=false
# 本番で複数サブドメイン共有時のみ設定（例: .example.com）
# COOKIE_DOMAIN=

# =============================================================================
# Supabase (Optional - AUTH_PROVIDER=supabase 時または既存ストレージ用)
# =============================================================================
# SUPABASE_URL=https://[PROJECT_REF].supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_JWT_SECRET=your-jwt-secret  # AUTH_PROVIDER=supabase 時のみ必須

# =============================================================================
# Supabase Storage (for COG files)
# =============================================================================
# Bucket name for storing COG files
SUPABASE_STORAGE_BUCKET=geo-tiles

# Public URL for storage (optional, auto-generated if not set)
# SUPABASE_STORAGE_PUBLIC_URL=https://[PROJECT_REF].supabase.co/storage/v1/object/public/geo-tiles

# =============================================================================
# Vercel Blob (Alternative to Supabase Storage)
# =============================================================================
# BLOB_READ_WRITE_TOKEN=your-vercel-blob-token

# =============================================================================
# CORS
# =============================================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=*

# =============================================================================
# Raster Tile Settings
# =============================================================================
# Default scale range for raster tiles
RASTER_DEFAULT_SCALE_MIN=0
RASTER_DEFAULT_SCALE_MAX=3000

# Default output format
RASTER_DEFAULT_FORMAT=png

# Maximum preview image size
RASTER_MAX_PREVIEW_SIZE=1024

# Tile size in pixels
RASTER_TILE_SIZE=256
