# geo-base MCP Server Environment Variables
# Copy this file to .env and update the values

# ============================================================
# Tile Server Configuration
# ============================================================

# Base URL of the geo-base tile server API
# For local development (api/ uses port 8000):
TILE_SERVER_URL=http://localhost:8000
# For production (Fly.io):
# TILE_SERVER_URL=https://geo-base-api.fly.dev

# ============================================================
# Authentication (Optional)
# ============================================================

# JWT token for authenticated API requests
# Required for accessing private tilesets
# Obtain via geo-base local auth provider against the same TILE_SERVER_URL host
# (local: http://localhost:8000, production: https://geo-base-api.fly.dev).
#
# With jq (recommended):
#   curl -s -X POST $TILE_SERVER_URL/api/auth/login \
#     -H "Content-Type: application/json" \
#     -d '{"email":"<your-email>","password":"<your-password>"}' \
#     | jq -r .access_token
# (jq が未導入の場合は `brew install jq` / `apt install jq` 等で導入してください)
#
# Without jq (Python fallback):
#   curl -s -X POST $TILE_SERVER_URL/api/auth/login \
#     -H "Content-Type: application/json" \
#     -d '{"email":"<your-email>","password":"<your-password>"}' \
#     | python -c 'import json, sys; print(json.load(sys.stdin)["access_token"])'
#
# API_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================
# Server Configuration
# ============================================================

# Server name (shown in Claude Desktop)
SERVER_NAME=geo-base

# Server version
SERVER_VERSION=0.1.0

# Environment (development/production)
ENVIRONMENT=development

# Debug mode (true/false)
DEBUG=false

# ============================================================
# MCP Transport Configuration
# ============================================================

# Transport mode for MCP server
# Options:
#   stdio            - For local Claude Desktop (default)
#   sse              - For remote connections via Fly.io
#   streamable-http  - Alternative HTTP transport
MCP_TRANSPORT=stdio

# Host to bind for HTTP transports (sse, streamable-http)
MCP_HOST=0.0.0.0

# Port to bind for HTTP transports
MCP_PORT=8080

# ============================================================
# HTTP Client Configuration
# ============================================================

# HTTP request timeout in seconds
HTTP_TIMEOUT=30.0
